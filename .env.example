# ---- Database ---------------------------------------------------------------
PIPELINE_DSN=postgresql://trader:trader_dev@127.0.0.1:5432/trading

# ---- Alpaca (paper account) ---------------------------------------------------
ALPACA_KEY_ID=your_key_id_here
ALPACA_SECRET_KEY=your_secret_here
# wss endpoint for the news stream (paper + live use the same news host)
ALPACA_NEWS_WS=wss://stream.data.alpaca.markets/v1beta1/news

# ---- SEC EDGAR ------------------------------------------------------------------
# Required by SEC fair-access policy: identifies your poller in the User-Agent.
EDGAR_CONTACT=ian.gillbanks@gmail.com
EDGAR_APP_NAME=Ians Trading System

# ---- Vector store (C2) ----------------------------------------------------------
# Empty/unset = qdrant-client local mode with on-disk storage at QDRANT_PATH.
# On the Spark, run the Qdrant docker container and set QDRANT_URL=http://127.0.0.1:6333
QDRANT_URL=
QDRANT_PATH=/home/claude/qdrant-local

# ---- Embedder --------------------------------------------------------------------
# "bge" = sentence-transformers BAAI/bge-small-en-v1.5 (requires [embed] extra + model download)
# "hash" = deterministic test embedder (no downloads; dev/test only)
EMBEDDER=hash
