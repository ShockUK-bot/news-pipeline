[Unit]
Description=a7-eod EOD report generator (oneshot, fired by a7-eod.timer)
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=oneshot
User=trader
WorkingDirectory=/opt/pipeline
Environment=PYTHONPATH=/opt/pipeline/src
EnvironmentFile=/etc/pipeline/pipeline.env
ExecStart=/opt/pipeline/.venv/bin/python -m a7_report.service
TimeoutStartSec=1200
StandardOutput=journal
StandardError=journal
