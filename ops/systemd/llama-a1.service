[Unit]
Description=llama-server Fast slot (A1 triage) — Qwen3-8B Q6_K on :8080
After=network-online.target

[Service]
Type=simple
User=trader
ExecStart=/opt/llama.cpp/build/bin/llama-server \
  -m /opt/models/qwen3-8b-q6_k.gguf \
  --host 127.0.0.1 --port 8080 \
  -c 8192 --parallel 2 \
  -ngl 999 --no-mmap
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
