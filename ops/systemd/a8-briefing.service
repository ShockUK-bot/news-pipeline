[Unit]
Description=a8 morning briefing (oneshot, fired by a8-briefing.timer)
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=oneshot
User=trader
WorkingDirectory=/opt/pipeline
Environment=PYTHONPATH=/opt/pipeline/src
EnvironmentFile=/etc/pipeline/pipeline.env
ExecStart=/opt/pipeline/.venv/bin/python -m a8_briefing.service
TimeoutStartSec=900
StandardOutput=journal
StandardError=journal
