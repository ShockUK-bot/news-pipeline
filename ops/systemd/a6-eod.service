[Unit]
Description=a6 EOD overnight-hold check (oneshot, fired by a6-eod.timer)
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=oneshot
User=trader
WorkingDirectory=/opt/pipeline
Environment=PYTHONPATH=/opt/pipeline/src
EnvironmentFile=/etc/pipeline/pipeline.env
ExecStart=/opt/pipeline/.venv/bin/python -m a6_position_review.service eod
TimeoutStartSec=900
StandardOutput=journal
StandardError=journal
