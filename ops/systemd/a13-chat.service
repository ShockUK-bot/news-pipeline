[Unit]
Description=a13-chat Service (trading pipeline — operator chat)
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=simple
User=trader
WorkingDirectory=/opt/pipeline
Environment=PYTHONPATH=/opt/pipeline/src
EnvironmentFile=/etc/pipeline/pipeline.env
ExecStart=/opt/pipeline/.venv/bin/python -m a13_chat.service
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
