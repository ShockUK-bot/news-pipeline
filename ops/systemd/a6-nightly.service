[Unit]
Description=a6 nightly position deep review (oneshot, fired by a6-nightly.timer)
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=oneshot
User=trader
WorkingDirectory=/opt/pipeline
Environment=PYTHONPATH=/opt/pipeline/src
EnvironmentFile=/etc/pipeline/pipeline.env
ExecStart=/opt/pipeline/.venv/bin/python -m a6_position_review.service nightly
TimeoutStartSec=2700
StandardOutput=journal
StandardError=journal
