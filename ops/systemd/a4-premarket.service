[Unit]
Description=a4-premarket action sheet (oneshot, fired by a4-premarket.timer)
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=oneshot
User=trader
WorkingDirectory=/opt/pipeline
Environment=PYTHONPATH=/opt/pipeline/src
EnvironmentFile=/etc/pipeline/pipeline.env
ExecStart=/opt/pipeline/.venv/bin/python -m a4_premarket.service
TimeoutStartSec=1800
StandardOutput=journal
StandardError=journal
