[Unit]
Description=earnings-calendar refresh (oneshot, fired by earnings-calendar.timer)
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=oneshot
User=trader
WorkingDirectory=/opt/pipeline
Environment=PYTHONPATH=/opt/pipeline/src
EnvironmentFile=/etc/pipeline/pipeline.env
ExecStart=/opt/pipeline/.venv/bin/python -m c1_ingestion.earnings
TimeoutStartSec=300
StandardOutput=journal
StandardError=journal
