# /etc/pipeline/pipeline.env — mode 600, owner trader (baseline §11.6)
PIPELINE_DSN=postgresql://trader:CHANGE_ME@127.0.0.1:5432/trading
ALPACA_KEY_ID=
ALPACA_SECRET_KEY=
EDGAR_CONTACT=ian.gillbanks@gmail.com
EDGAR_APP_NAME="Ians Trading System"
QDRANT_URL=http://127.0.0.1:6333
EMBEDDER=bge
# BROKER / MARKETDATA default to 'alpaca' in code — do not set to 'fake' here.
# Notes (v0.4.3): DB password must contain only letters and digits (no $ % @ : /).
# Values with spaces must be double-quoted (safe for both systemd and shell sourcing).
#
# Dashboard (C6) credentials — required:
# DASH_USER=
# DASH_PASS=
# DASH_KILL_TOKEN=
